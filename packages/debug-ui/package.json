{
  "name": "@telorun/debug-ui",
  "version": "0.1.0",
  "description": "Browser-safe debug event UI for Telo: wire types, filtering, SSE client, and React components for watching a running app's event stream.",
  "keywords": [
    "telo",
    "debug",
    "events",
    "sse"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/telo.git",
    "directory": "packages/debug-ui"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components": {
      "source": "./src/components/index.ts",
      "types": "./src/components/index.ts",
      "bun": "./src/components/index.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./app-dist/*": "./app-dist/*",
    "./app-single/*": "./app-single/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**",
    "app-dist/**",
    "app-single/**",
    "src/**"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.single.config.ts",
    "build:lib": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@telorun/debug-wire": "workspace:*",
    "lucide-react": "^1.8.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "^5.0.0",
    "vite": "^6",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.8"
  }
}
