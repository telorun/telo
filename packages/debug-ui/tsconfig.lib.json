{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist", "app-dist", "**/*.test.ts", "**/*.test.tsx"],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
