{
  "name": "@telorun/kernel",
  "version": "0.2.5",
  "description": "Telo Runtime - A lightweight, polyglot execution host.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/**"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "digly",
    "runtime",
    "execution",
    "manifest"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@telorun/analyzer": "workspace:*",
    "@telorun/sdk": "workspace:*",
    "@telorun/yaml-cel-templating": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "@marcbachmann/cel-js": "^7.5.3",
    "packageurl-js": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
