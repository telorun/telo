# Local environment template for examples in this directory.
#
# Copy this file to `.env.local` (which is git-ignored) and fill in real
# values. The CLI auto-loads `.env.local` from the manifest's directory
# when you run `telo …`, so any keys here become `env.<NAME>` inside the
# manifest's root-module `compile` scope (and feed `variables`/`secrets`
# bound to these env keys).

# chat-console.yaml — OpenAI streaming chat REPL
OPENAI_API_KEY=sk-...

# configurable-http-server.yaml — upstream URL + secret echoed by the demo
API_BASE_URL=https://api.example.com
STRIPE_SECRET_KEY=sk_test_demo_value
