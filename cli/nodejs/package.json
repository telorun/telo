{
  "name": "@telorun/cli",
  "version": "0.50.0",
  "description": "Telo CLI - Command-line interface for the Telo runtime.",
  "keywords": [
    "telo",
    "cli",
    "runtime"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/telo.git",
    "directory": "cli/nodejs"
  },
  "homepage": "https://github.com/telorun/telo#readme",
  "bugs": {
    "url": "https://github.com/telorun/telo/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "telo": "./bin/telo.mjs"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc",
    "prepack": "cp ../../LICENSE . && cp ../README.md . && node ../../scripts/prepack-bake-overrides.mjs .",
    "postpack": "rm -f LICENSE && rm -f README.md"
  },
  "dependencies": {
    "@telorun/analyzer": "workspace:*",
    "@telorun/glob": "workspace:*",
    "@telorun/ide-support": "workspace:*",
    "@telorun/kernel": "workspace:*",
    "@telorun/sdk": "workspace:*",
    "@telorun/templating": "workspace:*",
    "dotenv": "^17.4.0",
    "packageurl-js": "^2.0.1",
    "semver": "^7.7.3",
    "tar-stream": "^3.1.7",
    "yaml": "^2.8.3",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@telorun/debug-ui": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.7.1",
    "@types/tar-stream": "^3.1.3",
    "@types/yargs": "^17.0.33",
    "nock": "^14.0.15",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  }
}
