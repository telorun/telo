{
  "name": "@telorun/rate-limit",
  "version": "0.2.0",
  "description": "Telo rate-limit module — sliding-window RateLimit.Guard backed by any Cache.Store.",
  "keywords": [
    "telo",
    "rate-limit",
    "throttle",
    "sliding-window"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/telo.git",
    "directory": "modules/rate-limit/nodejs"
  },
  "homepage": "https://github.com/telorun/telo#readme",
  "bugs": {
    "url": "https://github.com/telorun/telo/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./guard": {
      "types": "./dist/guard-controller.d.ts",
      "bun": "./src/guard-controller.ts",
      "import": "./dist/guard-controller.js"
    },
    "./budget": {
      "types": "./dist/budget-controller.d.ts",
      "bun": "./src/budget-controller.ts",
      "import": "./dist/budget-controller.js"
    }
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "cp ../../../LICENSE . && cp ../../../README.md .",
    "postpack": "rm -f LICENSE && rm -f README.md"
  },
  "dependencies": {
    "@telorun/cache": "workspace:*"
  },
  "devDependencies": {
    "@telorun/sdk": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@telorun/sdk": "*"
  }
}
