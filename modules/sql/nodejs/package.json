{
  "name": "@telorun/sql",
  "version": "0.1.8",
  "description": "Telo SQL module - SQL database resource kinds for Telo manifests.",
  "keywords": [
    "telo",
    "sql",
    "database",
    "sqlite",
    "postgres"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/telo.git",
    "directory": "modules/sql/nodejs"
  },
  "homepage": "https://github.com/telorun/telo#readme",
  "bugs": {
    "url": "https://github.com/telorun/telo/issues"
  },
  "type": "module",
  "exports": {
    "./sql-connection": {
      "bun": "./src/sql-connection-controller.ts",
      "import": "./dist/sql-connection-controller.js"
    },
    "./sql-query": {
      "bun": "./src/sql-query-controller.ts",
      "import": "./dist/sql-query-controller.js"
    },
    "./sql-select": {
      "bun": "./src/sql-select-controller.ts",
      "import": "./dist/sql-select-controller.js"
    },
    "./sql-exec": {
      "bun": "./src/sql-exec-controller.ts",
      "import": "./dist/sql-exec-controller.js"
    },
    "./sql-transaction": {
      "bun": "./src/sql-transaction-controller.ts",
      "import": "./dist/sql-transaction-controller.js"
    },
    "./sqlite-driver": {
      "bun": "./src/sqlite-driver-bun.ts",
      "import": "./dist/sqlite-driver-node.js"
    },
    "./sql-migration": {
      "bun": "./src/sql-migration-controller.ts",
      "import": "./dist/sql-migration-controller.js"
    },
    "./sql-migrations": {
      "bun": "./src/sql-migrations-controller.ts",
      "import": "./dist/sql-migrations-controller.js"
    }
  },
  "files": [
    "dist",
    "src/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "cp ../../../LICENSE . && cp ../../../README.md .",
    "postpack": "rm -f LICENSE && rm -f README.md"
  },
  "dependencies": {
    "@telorun/sdk": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "pg": "^8.20.0",
    "kysely": "^0.28.15"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
