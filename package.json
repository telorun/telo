{
  "name": "@telorun/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Telo Runtime: A lightweight, polyglot execution host.",
  "scripts": {
    "telo": "bun ./cli/nodejs/bin/telo.ts",
    "telo:node": "node ./cli/nodejs/bin/telo.mjs",
    "publish": "bun ./cli/nodejs/bin/telo.ts publish --registry=http://registry.telo.localhost:8060",
    "check": "bun ./cli/nodejs/bin/telo.ts check",
    "test": "bun ./cli/nodejs/bin/telo.ts ./test-suite.yaml",
    "test:node": "node ./cli/nodejs/bin/telo.mjs ./test-suite.yaml",
    "release": "node scripts/release.mjs",
    "release:modules": "node scripts/release-modules.mjs",
    "release:platform": "node scripts/release.mjs"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "bun": "^1.3.9",
    "@changesets/cli": "^2.29.8"
  }
}
