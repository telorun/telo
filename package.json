{
  "name": "@telorun/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Telo Runtime: A lightweight, polyglot execution host.",
  "keywords": [
    "telo",
    "runtime",
    "declarative",
    "manifest",
    "orchestration"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/telo.git"
  },
  "homepage": "https://github.com/telorun/telo#readme",
  "bugs": {
    "url": "https://github.com/telorun/telo/issues"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "telo": "bun ./cli/nodejs/bin/telo.ts",
    "telo:node": "node ./cli/nodejs/bin/telo.mjs",
    "publish": "bun ./cli/nodejs/bin/telo.ts publish",
    "publish:local": "bun ./cli/nodejs/bin/telo.ts publish --registry=http://registry.telo.localhost:8060",
    "check": "bun ./cli/nodejs/bin/telo.ts check",
    "test": "bun ./cli/nodejs/bin/telo.ts ./test-suite.yaml",
    "test:node": "node ./cli/nodejs/bin/telo.mjs ./test-suite.yaml",
    "ci": "pnpm run check modules/*/telo.yaml && pnpm run check examples/*.yaml && pnpm run test && pnpm -r build && pnpm run test:node",
    "release": "node scripts/release.mjs",
    "release:modules": "node scripts/release-modules.mjs",
    "release:platform": "node scripts/release.mjs"
  },
  "devDependencies": {
    "bun": "^1.3.9",
    "@changesets/cli": "^2.29.8"
  }
}
