{
  "name": "@telorun/ai-openai",
  "version": "0.9.0",
  "description": "Telo Ai.OpenaiModel — OpenAI-compatible provider for Ai.Model (direct /chat/completions HTTP API, no vendor SDK).",
  "keywords": [
    "telo",
    "ai",
    "openai",
    "llm"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/telo.git",
    "directory": "modules/ai-openai/nodejs"
  },
  "homepage": "https://github.com/telorun/telo#readme",
  "bugs": {
    "url": "https://github.com/telorun/telo/issues"
  },
  "type": "module",
  "main": "./dist/openai-model-controller.js",
  "module": "./dist/openai-model-controller.js",
  "types": "./dist/openai-model-controller.d.ts",
  "exports": {
    "./openai-model": {
      "types": "./dist/openai-model-controller.d.ts",
      "bun": "./src/openai-model-controller.ts",
      "import": "./dist/openai-model-controller.js"
    }
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "cp ../../../LICENSE . && cp ../../../README.md .",
    "postpack": "rm -f LICENSE && rm -f README.md"
  },
  "dependencies": {
    "@telorun/ai": "workspace:*"
  },
  "devDependencies": {
    "@telorun/sdk": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@telorun/sdk": "*"
  }
}
