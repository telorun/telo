{
  "name": "@telorun/http-dispatch",
  "version": "0.2.0",
  "description": "Telo HTTP Dispatch - Transport-neutral returns:/catches: rendering shared between HTTP-shaped transports (http-server, lambda, …).",
  "keywords": [
    "telo",
    "http",
    "dispatch",
    "response"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/telo.git",
    "directory": "packages/http-dispatch/nodejs"
  },
  "homepage": "https://github.com/telorun/telo#readme",
  "bugs": {
    "url": "https://github.com/telorun/telo/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./test-utils": {
      "source": "./src/test-utils/sink-contract.ts",
      "types": "./dist/test-utils/sink-contract.d.ts",
      "bun": "./src/test-utils/sink-contract.ts",
      "import": "./dist/test-utils/sink-contract.js",
      "default": "./dist/test-utils/sink-contract.js"
    }
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "cp ../../../LICENSE . && cp ../../../README.md .",
    "postpack": "rm -f LICENSE && rm -f README.md"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@telorun/sdk": "workspace:*"
  },
  "peerDependencies": {
    "vitest": "^2.1.8 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  }
}
