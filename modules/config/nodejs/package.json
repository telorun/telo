{
  "name": "@telorun/config",
  "version": "0.1.5",
  "description": "Telo Config module - Configuration and variable providers for Telo manifests.",
  "keywords": [
    "telo",
    "config",
    "variables",
    "secrets"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/telo.git",
    "directory": "modules/config/nodejs"
  },
  "homepage": "https://github.com/telorun/telo#readme",
  "bugs": {
    "url": "https://github.com/telorun/telo/issues"
  },
  "type": "module",
  "exports": {
    "./env-variable-store-controller": {
      "types": "./dist/env-variable-store-controller.d.ts",
      "bun": "./src/env-variable-store-controller.ts",
      "import": "./dist/env-variable-store-controller.js"
    },
    "./variables-controller": {
      "types": "./dist/variables-controller.d.ts",
      "bun": "./src/variables-controller.ts",
      "import": "./dist/variables-controller.js"
    },
    "./secrets-controller": {
      "types": "./dist/secrets-controller.d.ts",
      "bun": "./src/secrets-controller.ts",
      "import": "./dist/secrets-controller.js"
    },
    "./env-controller": {
      "types": "./dist/env-controller.d.ts",
      "bun": "./src/env-controller.ts",
      "import": "./dist/env-controller.js"
    }
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "cp ../../../LICENSE . && cp ../README.md .",
    "postpack": "rm -f LICENSE && rm -f README.md"
  },
  "dependencies": {
    "@telorun/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
