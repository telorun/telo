{
  "name": "@telorun/sql-sqlite",
  "version": "0.2.0",
  "description": "Telo SqlSqlite.Connection — SQLite backend for the Sql.Connection abstract (better-sqlite3 / bun:sqlite, transactional DDL).",
  "keywords": [
    "telo",
    "sql",
    "sqlite"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/telo.git",
    "directory": "modules/sql-sqlite/nodejs"
  },
  "homepage": "https://github.com/telorun/telo#readme",
  "bugs": {
    "url": "https://github.com/telorun/telo/issues"
  },
  "type": "module",
  "exports": {
    "./connection": {
      "bun": "./src/connection-controller.ts",
      "import": "./dist/connection-controller.js"
    },
    "./sqlite-driver": {
      "bun": "./src/sqlite-driver-bun.ts",
      "import": "./dist/sqlite-driver-node.js"
    }
  },
  "files": [
    "dist",
    "src/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "cp ../../../LICENSE . && cp ../../../README.md .",
    "postpack": "rm -f LICENSE && rm -f README.md"
  },
  "dependencies": {
    "@telorun/sql": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "kysely": "^0.28.15"
  },
  "devDependencies": {
    "@telorun/sdk": "workspace:*",
    "@types/better-sqlite3": "^7.0.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@telorun/sdk": "*"
  }
}
